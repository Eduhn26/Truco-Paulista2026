NODE_ENV=development
PORT=3000

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=51214

DATABASE_URL=postgresql://postgres:postgres@localhost:51214/postgres?schema=public
DOCKER_DATABASE_URL=postgresql://postgres:postgres@postgres:5432/postgres?schema=public

# NOTE: Used by the debug WebSocket client script when the server is not reached
# through the default localhost:PORT convention.
WS_URL=http://localhost:3000

# NOTE: Explicit frontend origin for HTTP CORS.
# Local frontend default:
# - http://localhost:5173
# Production frontend:
# - set this to the published frontend origin
CORS_ORIGIN=http://localhost:5173

# NOTE: Replace placeholder values before any real production deployment.
AUTH_TOKEN_SECRET=replace-with-a-real-secret
AUTH_TOKEN_EXPIRES_IN=7d

GOOGLE_CLIENT_ID=dummy-google-client-id
GOOGLE_CLIENT_SECRET=dummy-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

GITHUB_CLIENT_ID=dummy-github-client-id
GITHUB_CLIENT_SECRET=dummy-github-client-secret
GITHUB_CALLBACK_URL=http://localhost:3000/auth/github/callback

PYTHON_BOT_ENABLED=true
PYTHON_BOT_BASE_URL=http://localhost:8000
PYTHON_BOT_TIMEOUT_MS=1500

# NOTE: Local Compose keeps migration as a dedicated one-shot service.
# Set this to true only in single-container hosted environments where
# migrations must happen during container startup.
RUN_MIGRATIONS_ON_BOOT=false

# NOTE: Runtime hardening for socket event abuse.
SOCKET_RATE_LIMIT_WINDOW_MS=10000
SOCKET_RATE_LIMIT_MAX_EVENTS=40
SOCKET_RATE_LIMIT_BLOCK_MS=15000

# -----------------------------------------------------------------------------
# Frontend environment contract
# -----------------------------------------------------------------------------
# VITE_APP_ENV
# - development: local/dev usage, manual backend override may stay available
# - production: frontend should trust the published API boundary from env
VITE_APP_ENV=development

# VITE_DEFAULT_BACKEND_URL
# Local example:
# - http://localhost:3000
# Production example:
# - https://your-backend-domain.onrender.com
VITE_DEFAULT_BACKEND_URL=http://localhost:3000